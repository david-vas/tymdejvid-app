rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isCoach() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'coach';
    }

    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // ── Users ──────────────────────────────────────────────────────────
    // Všichni přihlášení čtou všechny profily (žebříček, docházka, admin)
    // Každý uživatel píše jen svůj profil; trenér píše kohokoliv
    match /users/{userId} {
      allow read:   if isAuth();
      allow create: if isAuth();                    // registrace nového účtu
      allow update: if isOwner(userId) || isCoach();
      allow delete: if isCoach();
    }

    // ── Training config (patches / extras / deletes) ───────────────────
    match /config/{docId} {
      allow read:  if isAuth();
      allow write: if isCoach();
    }

    // ── News / Novinky ─────────────────────────────────────────────────
    match /news/{newsId} {
      allow read:                    if isAuth();
      allow create, update, delete:  if isCoach();
    }

    // ── FCM tokeny ─────────────────────────────────────────────────────
    // Každý uživatel čte/píše jen svůj token; trenér čte všechny (pro broadcast)
    match /fcmTokens/{userId} {
      allow read:  if isOwner(userId) || isCoach();
      allow write: if isOwner(userId);
    }

    // ── Fallback – vše ostatní zakázáno ───────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
